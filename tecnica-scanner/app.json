{
  "expo": {
    "name": "Tecnica Scanner",
    "slug": "tecnica-scanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#004063"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "hu.tecnicagroup.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes on production assets."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004063"
      },
      "package": "hu.tecnicagroup.scanner",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan QR codes on production assets."
        }
      ]
    ]
  }
}
